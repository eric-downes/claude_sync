{
  "name": "claude-sync",
  "version": "0.1.0",
  "description": "Tool for synchronizing between Claude Code and Claude AI projects",
  "main": "dist/index.js",
  "bin": {
    "claude-sync": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "claude",
    "anthropic",
    "sync",
    "mcp",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.14.1",
    "chokidar": "^4.0.3",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "dotenv": "^16.4.1",
    "electron-store": "^8.1.0",
    "level": "^8.0.1",
    "level-read-stream": "^1.1.0",
    "playwright": "^1.52.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^8.56.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.1",
    "vitest": "^3.1.4"
  },
  "type": "module"
}
